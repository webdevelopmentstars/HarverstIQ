# MongoDB
MONGODB_URI=mongodb://admin:password@mongo:27017/harvestiq?authSource=admin
MONGODB_ROOT_USER=admin
MONGODB_ROOT_PASSWORD=password

# Redis
REDIS_URL=redis://:@redis:6379/0

# Google Sheets
GOOGLE_SHEETS_ID=
GOOGLE_CREDENTIALS_PATH=./config/service-account.json

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32_chars

# API
API_PORT=4000
API_BASE_URL=http://api:4000
API_CORS_ORIGIN=http://localhost:3000,http://web:3000

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Python Scraper
SCRAPER_PORT=4001
SCRAPER_SECRET=your_scraper_shared_secret_min_32_chars
MAX_BROWSERS=5
DEFAULT_DELAY_MIN=1
DEFAULT_DELAY_MAX=5
USER_AGENTS_FILE=./config/user_agents.json

# Environment
NODE_ENV=development
PYTHON_ENV=development
